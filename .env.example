# Railway (backend) — pick ONE approach:
#
# A) DATABASE_URL = Session pooler URI from Supabase Connect (NOT Direct).
#    If password contains @, use %40 in the URI string only.
#
# B) If password has special chars, prefer discrete vars (no URL encoding):
# SUPABASE_POOLER_HOST=   (from Session pooler tab, e.g. aws-0-REGION.pooler.supabase.com)
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_USER=       (e.g. postgres.your_project_ref)
DATABASE_URL=

# Alternative to DATABASE_URL (see DEPLOYMENT_README.md):
# SUPABASE_POOLER_HOST=
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_USER=
# SUPABASE_POOLER_PORT=5432
# SUPABASE_PROJECT_REF=
# SUPABASE_DB_NAME=postgres

# Netlify (frontend build) — optional if Railway URL is not the default
# VITE_API_BASE_URL=https://your-service.up.railway.app
