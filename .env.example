# Railway (backend service) — required for API
# Copy Session pooler URI from Supabase → Connect (encode @ in password as %40)
DATABASE_URL=

# Alternative to DATABASE_URL:
# SUPABASE_POOLER_HOST=
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_USER=
# SUPABASE_POOLER_PORT=5432
# SUPABASE_PROJECT_REF=
# SUPABASE_DB_NAME=postgres

# Netlify (frontend build) — optional if Railway URL is not the default
# VITE_API_BASE_URL=https://your-service.up.railway.app
